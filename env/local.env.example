# Server
PORT=8080
LOG_FORMAT=text
STATE_PATH="/tmp/state.json"

# Public IP watcher (local dev: use a writable STATE_PATH, e.g. /tmp/watcher-state.json)
CHECK_INTERVAL="30s"
STATE_PATH="/.watcher/state.json"

# Optional comma-separated HTTPS URLs (defaults to built-in chain if empty)
# IP_URLS="https://api.ipify.org,https://ipv4.icanhazip.com"

